PORT=3001

# Google Ads
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/channels/google/callback
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token

# Meta Ads
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_REDIRECT_URI=http://localhost:3001/api/channels/meta/callback

# TikTok Ads
TIKTOK_APP_ID=your-tiktok-app-id
TIKTOK_APP_SECRET=your-tiktok-app-secret
TIKTOK_REDIRECT_URI=http://localhost:3001/api/channels/tiktok/callback

# LinkedIn Ads
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:3001/api/channels/linkedin/callback

# X (Twitter) Ads — OAuth 2.0 with PKCE
X_CLIENT_ID=your-x-oauth2-client-id
X_CLIENT_SECRET=your-x-oauth2-client-secret
X_REDIRECT_URI=http://localhost:3001/api/channels/x_ads/callback

# Snapchat Ads
SNAPCHAT_CLIENT_ID=your-snapchat-client-id
SNAPCHAT_CLIENT_SECRET=your-snapchat-client-secret
SNAPCHAT_REDIRECT_URI=http://localhost:3001/api/channels/snapchat/callback

# Amazon Ads (Login with Amazon — pick region: NA / EU / FE)
AMAZON_CLIENT_ID=your-amazon-lwa-client-id
AMAZON_CLIENT_SECRET=your-amazon-lwa-client-secret
AMAZON_REDIRECT_URI=http://localhost:3001/api/channels/amazon/callback

# Pinterest Ads
PINTEREST_CLIENT_ID=your-pinterest-app-id
PINTEREST_CLIENT_SECRET=your-pinterest-app-secret
PINTEREST_REDIRECT_URI=http://localhost:3001/api/channels/pinterest/callback

# Mailchimp (email — OAuth 2.0)
MAILCHIMP_CLIENT_ID=your-mailchimp-oauth-client-id
MAILCHIMP_CLIENT_SECRET=your-mailchimp-oauth-client-secret
MAILCHIMP_REDIRECT_URI=http://localhost:3001/api/channels/mailchimp/callback
